<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <meta name="google-site-verification" content="google240b0f3d53be044f" />

    <% if (typeof file !== 'undefined' && file.title) { %>
        <title><%= file.title %> - Download Portal</title>
        <meta name="description" content="Download <%= file.title %> safely and securely from our official link.">
        <meta name="keywords" content="<%= file.title %>, visa process, pdf download, documents">
    <% } else { %>
        <title>Canada Travel Visa - Document Portal</title>
        <meta name="description" content="Official portal for downloading travel visa documents and guides.">
    <% } %>

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        .container {
            background-color: #ffffff;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 500px;
            width: 100%;
        }
        h1 {
            color: #2c3e50;
            font-size: 24px;
            margin-bottom: 20px;
        }
        p {
            color: #7f8c8d;
            font-size: 16px;
            line-height: 1.5;
        }
        .btn-download {
            display: inline-block;
            background-color: #27ae60;
            color: white;
            padding: 12px 30px;
            font-size: 18px;
            text-decoration: none;
            border-radius: 25px;
            font-weight: bold;
            margin-top: 25px;
            transition: background 0.3s ease;
        }
        .btn-download:hover {
            background-color: #219653;
        }
        .footer {
            margin-top: 30px;
            font-size: 12px;
            color: #bdc3c7;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>CANADA TRAVEL VISA</h1>
        <hr style="border: 0; height: 1px; background: #eee; margin: 20px 0;">

        <% if (typeof file !== 'undefined' && file.title) { %>
            <p>Your requested file is ready for download:</p>
            <h3 style="color: #2980b9;"><%= file.title %></h3>
            
            <a href="/download/<%= file.id %>" class="btn-download">📥 Download File</a>
        <% } else { %>
            <p>Welcome to the Secure Document Portal.</p>
            <p style="color: #e74c3c; font-weight: bold;">No file selected or uploaded yet.</p>
        <% } %>

        <div class="footer">
            © 2026 Canada Travel Visa Service. All rights reserved.
        </div>
    </div>

</body>
</html>
